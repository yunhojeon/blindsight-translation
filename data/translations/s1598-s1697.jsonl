{"id": "s1643", "status": "translated", "runs": [{"t": "텐트 안 누구에게서도 아닌 목소리였다. 나머지 데이터와 함께 떨리듯 스핀델의 팔을 타고 흘러내렸다, 거의 들릴까 말까 하게. "}, {"t": "바깥에서", "i": "emphasis"}, {"t": "."}], "speaker": null, "addressee": null, "register": null, "glossary_used": [], "translator_note": null, "revision": 1}
