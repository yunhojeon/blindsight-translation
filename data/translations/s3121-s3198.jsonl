{"id": "s3180", "status": "translated", "runs": [{"t": "\"했어요. 아이작이 그냥 경두개 자기자극 때문이라고 했어요. "}, {"t": "로르샤흐", "i": "title"}, {"t": "에서 오는.\""}], "speaker": "Siri", "addressee": "Cunningham", "register": "존댓말", "glossary_used": ["경두개 자기자극", "로르샤흐"], "translator_note": null, "revision": 1}
