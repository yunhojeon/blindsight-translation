{"id": "s1081", "status": "translated", "runs": [{"t": "스핀델이 고개를 저었다. \"있잖아요, 맨디. "}, {"t": "로르샤흐", "i": "title"}, {"t": "가 잭한테도 말을 걸고 있나요?\""}], "speaker": "Szpindel", "addressee": "Bates", "register": "존댓말", "glossary_used": ["로르샤흐"], "translator_note": null, "revision": 1}
