{"id": "s2610", "status": "translated", "runs": [{"t": "나는 헛기침을 했다. \"그러니까—\""}], "speaker": "Siri", "addressee": "James", "register": "존댓말", "glossary_used": [], "translator_note": null, "revision": 1}
