{"id": "s3242", "status": "translated", "runs": [{"t": "\"그가 설득하려는 건 "}, {"t": "당신", "i": "emphasis"}, {"t": "이 아니에요, 시리.\""}], "speaker": "Bates", "addressee": "Siri", "register": "존댓말", "glossary_used": [], "translator_note": null, "revision": 1}
