{"id": "s1778", "status": "translated", "runs": [{"t": "\"다른 무언가가 원인일 수도 있지 않을까요?\" 내가 물었다. \""}, {"t": "이", "i": true}, {"t": " 배에서 나오는 뭔가가요?\""}], "speaker": "Siri", "addressee": "Szpindel", "register": "존댓말", "glossary_used": [], "translator_note": null, "revision": 1}
