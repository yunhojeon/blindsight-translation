{"id": "s1459", "status": "translated", "runs": [{"t": "사샤가 대답했다: \"씨발, "}, {"t": "당연하죠", "i": true}, {"t": ". "}, {"t": "현장", "i": true}, {"t": " 작업이잖아요, 키튼. 퍼스트 콘택트라고요.\""}], "speaker": "James (Sascha)", "addressee": "Siri", "register": "존댓말", "glossary_used": [], "translator_note": null, "revision": 1}
